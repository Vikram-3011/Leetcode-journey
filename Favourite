@page "/favourites"
@rendermode InteractiveServer
@inject DatabaseController databaseController

@using BlazorApp.Singletons
@inject UserStateManager userState
@using MongoDB.Bson

@using BlazorApp.Models
@using BlazorApp.Controllers
@inject NavigationManager NavigationManager


<PageTitle>Favourites</PageTitle>

<MudText Typo="Typo.h3">Favourites</MudText>

<MudTable T="@Favourite" Items="@favourites" Hover="true">
    <HeaderContent>
        <MudTh>City</MudTh>
        <MudTh>Country</MudTh>
        <MudTh></MudTh>
        <MudTh></MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="City">@context.City</MudTd> // this is for the city to save
        <MudTd DataLabel="Country">@context.Country</MudTd> // this is for the country to save
        <MudTd>
            <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Favorite" Color="Color.Error" OnClick="@(() => RemoveFavourite(context.City))">Remove</MudButton>
        </MudTd>
        <MudTd>
            <MudButton Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Cloud" Color="Color.Primary" OnClick="@(() => ViewWeather(context.City))">View Weather</MudButton>
        </MudTd>
    </RowTemplate>
</MudTable>


@code 
{
    private List<Favourite>? favourites;

    protected override async Task OnInitializedAsync()
    {
        if (!userState.IsLoggedIn())
        {
            NavigationManager.NavigateTo("/login");
        }

        userState.OnChange += StateChange;
        await LoadFavourites();
    }

    private async Task LoadFavourites()
    {
        favourites = await databaseController.GetFavouritesByUserIdAsync(userState.User.Id);
        favourites ??= new List<Favourite>(); // Default to an empty list if no favourites
        StateHasChanged(); // Explicitly notify the UI to refresh
    }


    public async Task RemoveFavourite(string cityName)
    {
        if (string.IsNullOrWhiteSpace(cityName)) return;

        await databaseController.RemoveFavouriteAsync(userState.User.Id, cityName);
        await LoadFavourites(); // Reload favorites to reflect the change
    }




    public void ViewWeather(string city)
    {
        NavigationManager.NavigateTo("/weather/"+city);
    }

    private void StateChange() => InvokeAsync(StateHasChanged);

    public void Dispose() => userState.OnChange -= StateChange;
}
