class Solution {
    public int searchInsert(int[] nums, int target) {
        for (int i=0;i<nums.length;i++){
            if( nums[i] == target){
                return i;
            }
            
            if(nums[i] > target){
                return i;

            }
        }
        
    return nums.length; // this are used for if any number are not match then that number belongs to the very last position of the array , that why use this line in the code .
    
    }
}
