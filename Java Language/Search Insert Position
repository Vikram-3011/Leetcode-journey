=====================================Binery search method (Divide the part and search the value )=======================================
class Solution {
    public int searchInsert(int[] nums, int target) {  //this method to insert the position of the value are use the binery method , to divide the array inbetween the center if the target are smaller then we foucs on the left side else right side.
        int l = 0;
        int r = nums.length;

        while (l<r){
             int m =  (l+r) /2 ; // add the two value "l,r" and divide that should be the center 

             if(nums[m] == target){  // center are the target value and return it 
                return m ;
             }
             if (nums[m] < target){ //move the value to the right 
                 l = m +1 ;
             }
             else
             r=m ; // its change the value of the r and m so the divided value also change .
        }
        return l;
    }
}


