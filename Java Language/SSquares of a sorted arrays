import java.util.Arrays;

class Solution {
    public int[] sortedSquares(int[] nums) {
        int[] sum = new int[nums.length]; // create the new array , which is length of the nums(input)

        for(int i=0; i<nums.length;i++){
           sum[i]= nums[i] * nums[i];  // multiple with same number and store it on the array 
        }
     Arrays.sort(sum); // sort the array
     return sum; 
    }
}
