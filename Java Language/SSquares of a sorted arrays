import java.util.Arrays;

class Solution {
    public int[] sortedSquares(int[] nums) {

      int[] sum =new int[nums.length]; 

        for(int i=0;i<nums.length;i++){
        sum[i] = nums[i] * nums[i];  // move teh left pat 
        }
        Arrays.sort(sum);  // sort the arrays 
         return sum;

    }
}
