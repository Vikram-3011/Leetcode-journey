class Solution {
    public boolean isPalindrome(int x) {
        
        if (x<0){

            return false;
        }
      int first = x ;
      int sum = 0 ;
        while(x>0){ // math based problem like sol useing the math formula
        int remainder = x%10 ; // using the "%" for get the remainder and why 10 means our sum are 10 based sum like reminder of 121 are 1 
        sum = sum*10+remainder; // store the vale to this place for the further sum 
        x=x/10; // here divide the value using the 10 for drop the last digit we already processed like 121/10 are 12.

        }
        if (first == sum){ // compare the both value if match true else false .

            return true;
        }
        return false;
    }
}


==============================Second Method to solve the problem =================================================


class Solution {
    public boolean isPalindrome(int x) {
        if (x<0) return false;  // negative number always not pailndrome

      String str =String.valueOf(x); // this line are used for converstion the int to string , we have to use the two pointer for this sum and its not even array so we cann't use the pointer method on single int so we convert into the string (121 --> "1","2","1") after change we use the pointer.

      int left =0;
      int right =str.length() -1;

      while(left<right){  // check until its meet the center using the loop
        if(str.charAt(left)!= str.charAt(right)){  // if not match anyone of the value its become no pailndrome
         
            return false;    
        }
        right--;  // move pointer from the each side
        left++;

      } 
      return true;
}}

