class Solution {
    public boolean isPalindrome(int x) {
        
        if (x<0){

            return false;
        }
      int first = x ;
      int sum = 0 ;
        while(x>0){
        int remainder = x%10 ;
        sum = sum*10+remainder;
        x=x/10;

        }
        if (first == sum){

            return true;
        }
        return false;
    }
}
