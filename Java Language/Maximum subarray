class Solution {
    public int maxSubArray(int[] nums) {
        int current_sum = 0 ;
        int max_num =Integer.MIN_VALUE ;

        for (int num : nums ){
            current_sum = current_sum + num ;
            max_num = Math.max(max_num,current_sum);

              if(current_sum <0){
            current_sum = 0;
        }
        }
      
        return max_num;
    }
}
