class Solution {
    public void moveZeroes(int[] nums) {
        int k=0;

        for(int i=0;i<nums.length;i++){

            if(nums[i] != 0){  // swap the number to first in the array 
                nums[k] = nums[i];
                k++;
            }
            
        }    
        while(k<nums.length){  //this loop wil excecute after the for loop finish ,its change the   number into zero at the index value of K in nums.  
            nums[k]=0;  //
            k++;
        }
    }
}
