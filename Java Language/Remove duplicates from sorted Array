class Solution {
    public int removeDuplicates(int[] nums) {
        if (nums.length == 0) return 0; 

        int count =1 ; // initilize the array with starting value , not from the first one start from the second value .
        for(int i=1; i<nums.length;i++){  
            if(nums[i] != nums[i-1]){   // Check the second and first number are the same are different , if diff change the position of the value. 
                nums[count] = nums[i]; //now the count value are 1 so if new unique value are found store in the place of the 1(second) and increment the count value. and store the next value to that position.  
                count++ ; 
            }
        } 
        return count; // returning count means its only view the returing range of the value and show that value to the output.
    }
}
