class Solution {
    public boolean containsNearbyDuplicate(int[] nums, int k) {
        
        HashSet summa = new HashSet<>(); // creating the hashset to store the unique value only

        for (int i=0;i<nums.length;i++){  // for loop to check the all value
            if(summa.contains(nums[i])){  // check the value are already exist in the set if exiist then return.

                return true;
            }

            summa.add(nums[i]); // add the current value to the set (extent) 

            if(summa.size() > k){  // check the size of the set its lessthan k or not if not then shrink it. 
                summa.remove(nums[i-k]);
            }

        }
        return false; // duplicate are not found then return false .
    }
}
