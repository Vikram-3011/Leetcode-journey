class Solution {
    public boolean containsNearbyDuplicate(int[] nums, int k) {
        HashSet<Integer> maadu = new HashSet<>();

        for (int i=0; i<nums.length;i++){
            if(maadu.contains(nums[i])){
                return true;
            }

            maadu.add(nums[i]);

            if(maadu.size() >k){
                maadu.remove(nums[i -k]);
            }
        }
        return false;
    }
}



